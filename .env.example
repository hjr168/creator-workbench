AIHOT_BASE_URL=https://aihot.virxact.com/api/public
AIHOT_TIMEOUT_MS=10000
AIHOT_MIN_INTERVAL_MS=1200

# Local development: optional, fallback to src/data/topic-radar.json.
# Production: required for write operations. Do not rely on local JSON in serverless deployment.
# When NODE_ENV=production and DATABASE_URL is empty, write operations are rejected.
DATABASE_URL=

# Optional: enables LLM topic-card generation. Without it, the app uses the local heuristic generator.
OPENAI_API_KEY=
TOPIC_RADAR_LLM_MODEL=gpt-4o-mini

# Optional: required only if calling POST /api/jobs/fetch-aihot from an external scheduler.
TOPIC_RADAR_JOB_SECRET=

# Optional: protects /api/miniapp/* endpoints. When set, the miniapp must send
# the matching value via `x-miniapp-token` header. Inject into the miniapp at
# build time as TARO_APP_MINIAPP_TOKEN (see miniapp/.env.example). Empty = open.
MINIAPP_API_TOKEN=

# Optional: used by scripts/bootstrap-server.sh when issuing Let's Encrypt certificates.
APP_DOMAIN=workbench.huangjiarong.top
EXPECTED_PUBLIC_IP=8.138.148.239
CERTBOT_EMAIL=

# Optional but recommended for public deployment.
# Protects /admin. When set, /admin requires login via /admin-login.
# When empty (local dev), /admin redirects to login and login always fails ——
# i.e. the admin panel is effectively locked. Set a strong password before going public.
ADMIN_PASSWORD=admin

# Optional. Extra secret mixed into the admin session cookie hash.
# Pair with ADMIN_PASSWORD. Change it to invalidate all existing admin sessions.
ADMIN_COOKIE_SECRET=
