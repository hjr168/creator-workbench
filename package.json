{
  "name": "creator-workbench",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "start": "HOSTNAME=127.0.0.1 PORT=3000 node .next/standalone/server.js",
    "build": "next build && npm run standalone:prepare",
    "standalone:prepare": "node scripts/prepare-standalone.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node scripts/migrate-json-to-postgres.mjs",
    "miniapp:install": "npm install --prefix miniapp",
    "miniapp:dev": "npm run dev:weapp --prefix miniapp",
    "miniapp:build": "npm run build:weapp --prefix miniapp",
    "miniapp:typecheck": "npm run typecheck --prefix miniapp"
  },
  "dependencies": {
    "lucide-react": "latest",
    "next": "latest",
    "pg": "^8.21.0",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/pg": "^8.20.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "tailwindcss": "latest",
    "typescript": "latest"
  }
}
