  "outlines": [
    {
      "id": "outline-001",
      "topicId": "topic-001",
      "titleCandidateId": "title-001",
      "opening": "很多人学 AI 工具的方式，是不断收藏新工具、看新教程、换新模型，但真正改变工作效率的不是工具数量，而是能否形成稳定工作流。",
      "corePoints": [
        "工具收藏不是能力，稳定复用才是能力。",
        "产品经理更需要把 AI 嵌入选题、调研、拆解、表达和复盘流程。",
        "每个工具都应该有明确入口、输出标准和复盘指标。"
      ],
      "cases": [
        "以公众号推文生产为例，先确认选题和大纲，再调用生成工具，能避免自动日报式的失控。",
        "以项目复盘为例，AI 负责整理材料，人负责判断观点和取舍。"
      ],
      "ending": "AI 工具真正进入工作流后，它不再是灵感玩具，而是一个稳定协作者。",
      "callToAction": "如果你也在搭建自己的 AI 工作流，可以先从一个固定内容生产流程开始。",
      "isConfirmed": true,
      "createdAt": "2026-06-03T10:35:00+08:00",
      "updatedAt": "2026-06-03T06:52:11.553Z"
    }
  ],
